---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { href: `/${lang === 'zh-hk' ? '' : 'en/'}`, label: t('nav.home') },
  { href: `/${lang === 'zh-hk' ? '' : 'en/'}our-farm`, label: t('nav.farm') },
  { href: `/${lang === 'zh-hk' ? '' : 'en/'}breeds`, label: t('nav.breeds') },
  { href: `/${lang === 'zh-hk' ? '' : 'en/'}shop`, label: t('nav.shop') },
  { href: `/${lang === 'zh-hk' ? '' : 'en/'}faq`, label: t('nav.faq') },
];

// Helper: Safely remove trailing slashes from any path (except the root "/")
const normalizePath = (path: string) => path.endsWith('/') && path.length > 1 ? path.slice(0, -1) : path;

// The current URL path safely normalized
const normalizedCurrent = normalizePath(Astro.url.pathname);

// Helper: Get the base path without the language prefix for the language switcher
const getPathWithoutLang = (pathname: string) => {
  if (pathname.startsWith('/en')) {
    const withoutEn = pathname.substring(3);
    return withoutEn === '' ? '/' : withoutEn;
  }
  return pathname;
};

// The clean base path for the language toggle
const cleanPath = getPathWithoutLang(normalizedCurrent);

// --- Build-time Promo Link Logic ---
const isShopPage = cleanPath === '/shop';

// If we are building the Shop page, just use anchor tags.
// Otherwise, use the full URL with the query parameter.
const fitnessHref = isShopPage
  ? '#product-fitness'
  : `/${lang === 'zh-hk' ? '' : 'en/'}shop?scrollTo=product-fitness`;

const bbqHref = isShopPage
  ? '#product-bbq'
  : `/${lang === 'zh-hk' ? '' : 'en/'}shop?scrollTo=product-bbq`;
---

<header>
  <div class="promo-bar">
    <div class="promo-carousel">
      <a href={fitnessHref} class="promo-slide" data-track="promo--shop-fitness">
        <span>{t('promo.text')} <strong>{t('promo.link')} &rarr;</strong></span>
      </a>
      <a href={bbqHref} class="promo-slide" data-track="promo--shop-bbq">
        <span>{t('promo.text2')} <strong>{t('promo.link')} &rarr;</strong></span>
      </a>
      <a href={fitnessHref} class="promo-slide" data-track="promo--shop-fitness">
        <span>{t('promo.text')} <strong>{t('promo.link')} &rarr;</strong></span>
      </a>
    </div>
  </div>

  <div class="container">
    <nav>
      <a href={`/${lang === 'zh-hk' ? '' : 'en/'}`} class="logo">
        <img src="/favicon.png" alt="Lantau Organic Rabbit Farm Logo" width="32" height="32" class="logo-icon" />
        <span>{t('site.name')}</span>
      </a>

      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-content" id="nav-content">
        <ul class="nav-links">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class={normalizePath(link.href) === normalizedCurrent ? 'active' : ''}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="lang-toggle">
          {Object.entries(languages).map(([l, label]) => {
            // Dynamically construct the target href based on the selected language
            const targetHref = l === 'zh-hk' ? cleanPath : (cleanPath === '/' ? '/en/' : `/en${cleanPath}`);
            return (
              <a
                href={targetHref}
                class={lang === l ? 'active' : ''}
              >
                {label}
              </a>
            );
          })}
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const navContent = document.getElementById('nav-content');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    navContent?.classList.toggle('active');
  });
</script>
