---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section>
  <div class="container">
    <h1>{t('faq.title')}</h1>
    <div class="faq-list">
      <div class="faq-item">
        <h3>{t('faq.q1')}</h3>
        <p>{t('faq.a1')}</p>
      </div>
      <div class="faq-item">
        <h3>{t('faq.q2')}</h3>
        <p>{t('faq.a2')}</p>
      </div>
      <div class="faq-item">
        <h3>{t('faq.q3')}</h3>
        <p>{t('faq.a3')}</p>
      </div>
      <div class="faq-item">
        <h3>{t('faq.q4')}</h3>
        <p>{t('faq.a4')}</p>
      </div>
      <div class="faq-item">
        <h3>{t('faq.q5')}</h3>
        <p>{t('faq.a5')}</p>
      </div>
      <div class="faq-item">
        <h3>{t('faq.q6')}</h3>
        <p>{t('faq.a6')}</p>
      </div>

      <!-- The Reveal Bubble -->
      <div class="faq-item reveal-question" data-track-visible="faq--viewed-reveal-bubble">
        <h3>{t('faq.reveal.q')}</h3>
        <p set:html={t('faq.reveal.a')} />

        <!-- Variant B Video Thumbnail (Hidden by default) -->
        <div id="ab-video-container" style="display: none; margin-top: 1.5rem;">
          <a
            href="https://www.youtube.com/watch?v=F3D49rjffEo"
            target="_blank"
            rel="noopener noreferrer"
            class="youtube-thumbnail-wrapper"
            data-track="faq--click-video-thumbnail"
            style="display: block;"
          >
            <!-- Using YouTube's high-quality default thumbnail -->
            <img src="https://img.youtube.com/vi/F3D49rjffEo/hqdefault.jpg" alt="Carnism Explained" class="yt-thumbnail-img" />
            <div class="yt-play-btn">
              <svg viewBox="0 0 68 48"><path class="yt-play-bg" d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="#212121" fill-opacity="0.8"></path><path d="M 45,24 27,14 27,34" fill="#fff"></path></svg>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const videoContainer = document.getElementById('ab-video-container');
    const textLink = document.getElementById('yt-text-link');
    const thumbnailLink = document.querySelector('.youtube-thumbnail-wrapper');

    // 1. Determine A/B Variant
    // Check localStorage to ensure consistency across refreshes for the same user
    let variant = localStorage.getItem('faq_ab_variant_youtube_thumbnail');

    if (!variant) {
      // 50/50 chance to get Variant A (Text only) or Variant B (Text + Thumbnail)
      variant = Math.random() < 0.5 ? 'A' : 'B';
      localStorage.setItem('faq_ab_variant_youtube_thumbnail', variant);
    }

    // 2. Log which variant the user saw to GoatCounter on page load
    if (window.goatcounter && window.goatcounter.count) {
      const variantDesc = variant === 'A' ? 'A (text only)' : 'B (text + thumbnail)';
      window.goatcounter.count({
        path: `Experiment: FAQ Variant ${variantDesc} Served`,
        title: `Experiment: FAQ Variant ${variantDesc} Served`,
        event: true,
        no_session: true
      });
    }

    // 3. Dynamically update the tracking IDs based on the variant
    if (textLink) {
      // Changes 'faq--youtube-carnism' to 'faq--youtube-carnism-A' or '-B'
      const baseTextTrack = textLink.getAttribute('data-track');
      textLink.setAttribute('data-track', `${baseTextTrack}-${variant}`);
    }

    if (variant === 'B') {
      if (videoContainer) videoContainer.style.display = 'block';

      // Ensure the thumbnail track ID also explicitly denotes Variant B for consistency
      if (thumbnailLink) {
        const baseThumbTrack = thumbnailLink.getAttribute('data-track');
        thumbnailLink.setAttribute('data-track', `${baseThumbTrack}-B`);
      }
    }
  });
</script>