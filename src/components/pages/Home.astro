---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Build the reviews array dynamically using translations
const reviews = [
  {
    name: t('reviews.1.name'),
    initials: 'SW',
    text: t('reviews.1.text'),
    image: '/assets/images/review-stew.jpg'
  },
  {
    name: t('reviews.2.name'),
    initials: 'JK',
    text: t('reviews.2.text'),
    image: '/assets/images/review-fitness.jpg'
  },
  {
    name: t('reviews.3.name'),
    initials: 'ML',
    text: t('reviews.3.text'),
    image: '/assets/images/review-roast.jpg'
  }
];
---

<section class="hero">
  <div class="container">
    <h1>{t('home.hero.title')}</h1>
    <p>{t('home.hero.subtitle')}</p>
    <a href={`/${lang === 'zh-hk' ? '' : 'en/'}breeds`} class="btn">{t('home.cta')}</a>
  </div>
</section>

<section>
  <div class="container split-section">
    <div class="split-content">
      <h2>{t('home.value.title')}</h2>
      <p>{t('home.value.p1')}</p>
      <p>{t('home.value.p2')}</p>
      <p class="feature-badge badge-eco" set:html={t('home.value.p3')} />
    </div>
    <div class="split-image">
      <img src="/assets/images/butchers-cut.jpg" alt="Premium plated rabbit meat" />
    </div>
  </div>
</section>

<section class="reviews-section">
  <div class="container">
    <h2 style="text-align: center;">{t('reviews.title')}</h2>
    <div class="reviews-grid">
      {reviews.map((review) => (
        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">{review.initials}</div>
            <div class="review-meta">
              <span class="review-name">{review.name}</span>
              <span class="review-stars">★★★★★</span>
            </div>
          </div>
          <p class="review-text">{review.text}</p>
          <img src={review.image} alt={`Customer photo by ${review.name}`} class="review-image" />
        </div>
      ))}
    </div>
  </div>
</section>

<section class="trust-badges-wrapper">
  <div class="container">
    <div class="trust-badges">

      <div class="trust-badge">
        <div class="trust-icon">
          <svg viewBox="0 0 24 24">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
          </svg>
        </div>
        <div class="trust-label">{t('badges.grassfed')}</div>
      </div>

      <div class="trust-badge">
        <div class="trust-icon">
          <svg viewBox="0 0 24 24">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
        </div>
        <div class="trust-label">{t('badges.hormone')}</div>
      </div>

      <div class="trust-badge">
        <div class="trust-icon">
          <svg viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
        <div class="trust-label">{t('badges.ethical')}</div>
      </div>

      <div class="trust-badge">
        <div class="trust-icon">
          <svg viewBox="0 0 24 24">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
            <path d="M3 3v5h5"></path>
          </svg>
        </div>
        <div class="trust-label">{t('badges.carbon')}</div>
      </div>

    </div>
  </div>
</section>