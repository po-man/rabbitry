---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const basePath = lang === 'zh-hk' ? '' : '/en';
---

<div class="page-banner">
  <img src="/assets/images/farm-fresh.jpg" alt="Our peaceful farm in Kam Tin" />
</div>

<section>
  <div class="container">
    <h1>{t('farm.story.title')}</h1>

    <div class="farm-section">
      <h2>{t('farm.story.subtitle1')}</h2>
      <p>{t('farm.story.p1')}</p>
      <p>{t('farm.story.p2')}</p>
      <p>{t('farm.story.p3')}</p>
      <p>{t('farm.story.p4')}</p>
      <img src="/assets/images/farm-petting.jpg" alt="Farmer holding a happy rabbit" class="farm-inline-img" />
    </div>

    <div class="farm-section">
      <h2>{t('farm.story.subtitle2')}</h2>
      <p>{t('farm.story.p5')}</p>
    </div>

    <div class="farm-section final-promise">
      <h2>{t('farm.story.subtitle3')}</h2>
      <p><strong>{t('farm.story.p6')}</strong></p>
    </div>

    <div class="farm-cta-section">
      <a href={`${basePath}/breeds`} class="btn" data-track="our-farm--cta-meet-friends">
        {t('farm.cta.primary')}
      </a>
      <a href={`${basePath}/faq`} class="btn btn-secondary" data-track="our-farm--cta-learn-humane">
        {t('farm.cta.secondary')}
      </a>
    </div>
  </div>
</section>