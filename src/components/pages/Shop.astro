---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const products = [
  { id: 'fitness', name: t('products.fitness.name'), desc: t('products.fitness.desc'), image: '/assets/images/fitness-pack.jpg' },
];
---

<div class="page-banner">
  <img src="/assets/images/sliced.jpg" alt="Healthy macro-friendly fitness meals" fetchpriority="high" decoding="sync" />
</div>

<section id="premium-products">
  <div class="container">
    <h1>{t('products.title')}</h1>
    <div class="breed-grid">
      {products.map((product) => (
        <div class="breed-card">
          <img src={product.image} alt={product.name} class="breed-img" />
          <div class="breed-info">
            <h3>{product.name}</h3>
            <p>{product.desc}</p>

            <div class="traceability-box">
              <div class="trace-title">{t('products.trace.title')}</div>
              <ul class="trace-details">
                <li>
                  <span class="trace-label">{t('products.trace.batch')}</span>
                  <span>{t('products.trace.name')}</span>
                </li>
                <li>
                  <span class="trace-label">{t('products.trace.age')}</span>
                  <span>{t('products.trace.age_val')}</span>
                </li>
                <li>
                  <span class="trace-label">{t('products.trace.hobby')}</span>
                  <span>{t('products.trace.hobby_val')}</span>
                </li>
              </ul>
            </div>

            <div class="feature-badge badge-freshness" set:html={t('products.freshness')} />

            <button class="btn add-to-cart" data-lang={lang} data-track="shop--add-to-cart">{t('breeds.add_to_cart')}</button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.add-to-cart');
  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const lang = button.getAttribute('data-lang');
      const faqPath = lang === 'zh-hk' ? '/faq' : '/en/faq';
      window.location.href = faqPath;
    });
  });
</script>